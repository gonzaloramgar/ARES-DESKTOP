<Window x:Class="AresAssistant.Views.AresMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES"
        Width="560" Height="520" SizeToContent="Manual"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="RootBorder" CornerRadius="20"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
            Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                <GradientStop Color="#0e0e18" Offset="0"/>
                <GradientStop Color="#06060c" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="12"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="45" ShadowDepth="0" Opacity="0.75"/>
        </Border.Effect>

        <Grid>
            <!-- Top accent glow line -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="20,20,0,0"
                    Margin="50,0" Opacity="0.85" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#ff2222" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="22,18,22,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: icon + title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <Path x:Name="IconPath"
                          Data="M 8,0 L 16,11 L 8,22 L 0,11 Z"
                          Fill="{DynamicResource AccentBrush}" Width="13" Height="19"
                          Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path.Effect>
                            <DropShadowEffect Color="#ff2222" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                        </Path.Effect>
                    </Path>
                    <TextBlock x:Name="TitleText" Text="ARES"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Message body -->
                <Border Grid.Row="1"
                        Background="#12121e" CornerRadius="10"
                        BorderBrush="#2a2a42" BorderThickness="1"
                        Padding="8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <TextBlock x:Name="MessageText"
                                   Margin="8,5"
                                   Foreground="{DynamicResource TextBrush}" FontSize="13"
                                   FontFamily="Consolas" LineHeight="22"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <!-- Buttons -->
                <StackPanel x:Name="ButtonPanel" Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,14,0,0"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.28"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="12" To="0" Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
