<UserControl x:Class="AresAssistant.Controls.FullHudModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1200" Height="800">

    <Border Background="#CC0d0d0d" CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Header spans all columns -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    Background="#0a0a0a" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 10,0 L 20,14 L 10,28 L 0,14 Z"
                              Fill="{DynamicResource AccentBrush}" Width="20" Height="28"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="ARES" FontFamily="Consolas" FontSize="18"
                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — HUD COMPLETO"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#555555" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="⊟" ToolTip="Modo overlay"
                                Click="ToggleMode_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="⚙" ToolTip="Ajustes"
                                Click="Settings_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="🗑" ToolTip="Limpiar chat"
                                Click="ClearChat_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="✕" ToolTip="Cerrar"
                                Click="Close_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Left panel: Tool list -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="0,0,1,0"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HERRAMIENTAS" FontSize="10"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontFamily="Consolas" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               FontFamily="Consolas" Foreground="#666666"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Center: Chat messages -->
            <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- User message on right -->
                                <Border Grid.Column="1"
                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#2a1010" CornerRadius="8,8,2,8"
                                        Padding="12,8" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </Border>

                                <!-- Assistant message on left -->
                                <Border Grid.Column="0"
                                        Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#1a1a1a" CornerRadius="8,8,8,2"
                                        Padding="12,8" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Right panel: System status -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="1,0,0,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="ESTADO DEL SISTEMA" FontSize="10" Foreground="#555555"
                               FontFamily="Consolas" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SystemStatus"
                               Text="Actualizando..." FontSize="11"
                               FontFamily="Consolas" Foreground="#666666"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="11" Margin="16,2" FontStyle="Italic"/>

            <!-- Input row -->
            <Border Grid.Row="3" Grid.Column="1"
                    Background="#0a0a0a" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="InputBox"
                             Style="{StaticResource AresTextBox}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Input_KeyDown"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             MinHeight="36" MaxHeight="120"
                             VerticalAlignment="Stretch"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="4000"/>

                    <Button Grid.Column="1" Content="Exportar"
                            Style="{StaticResource GhostButton}"
                            Margin="8,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Export_Click"/>

                    <Button Grid.Column="2" Content="Enviar →"
                            Style="{StaticResource AresButton}"
                            Margin="6,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Send_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
