<UserControl x:Class="AresAssistant.Views.FullHudModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1200" Height="800">

    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Header spans all columns -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    Background="#0a0a0a" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 10,0 L 20,14 L 10,28 L 0,14 Z"
                              Fill="{DynamicResource AccentBrush}" Width="20" Height="28"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}" FontFamily="Consolas" FontSize="18"
                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — HUD COMPLETO"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#777777" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="⊟" ToolTip="Modo overlay"
                                Click="ToggleMode_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="⚙" ToolTip="Ajustes"
                                Click="Settings_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="🗑" ToolTip="Limpiar chat"
                                Click="ClearChat_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                        <Button Content="✕" ToolTip="Cerrar"
                                Click="Close_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="32" Height="32" Padding="0" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Left panel: Tool list -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="0,0,1,0"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HERRAMIENTAS" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ToolNames.Count, StringFormat='{}{0} disponibles'}"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="#555555" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="5,3" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1f1f1f"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#777777"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Foreground" Value="#aaaaaa"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Center: Chat messages -->
            <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,5"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <!-- Role label -->
                                <TextBlock FontSize="10" FontFamily="Consolas"
                                           Margin="6,0,6,2"
                                           Foreground="{DynamicResource SubtextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="ARES"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Text" Value="TÚ"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Bubble -->
                                <Border MaxWidth="600" Padding="12,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1a1a1a"/>
                                            <Setter Property="CornerRadius" Value="8,8,8,2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background" Value="#2a1010"/>
                                                    <Setter Property="CornerRadius" Value="8,8,2,8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               FontSize="{DynamicResource FontSizeNormal}"
                                               Foreground="{DynamicResource TextBrush}"
                                               MaxWidth="580"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Right panel: System status -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
                    Background="#0f0f0f" BorderBrush="#222222" BorderThickness="1,0,0,0"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ESTADO" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Rectangle DockPanel.Dock="Top" Height="1" Fill="#222222" Margin="0,0,0,10"/>
                    <TextBlock x:Name="SystemStatus"
                               Text="{Binding StatusText, FallbackValue='Esperando...'}"
                               FontSize="11" DockPanel.Dock="Top"
                               FontFamily="Consolas" Foreground="#888888"
                               TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="11" Margin="16,2" FontStyle="Italic"/>

            <!-- Input row -->
            <Border Grid.Row="3" Grid.Column="1"
                    Background="#0a0a0a" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="InputBox"
                             Style="{StaticResource AresTextBox}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Input_KeyDown"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             MinHeight="36" MaxHeight="120"
                             VerticalAlignment="Stretch"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="4000"/>

                    <Button Grid.Column="1" Content="Exportar"
                            Style="{StaticResource GhostButton}"
                            Margin="8,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Export_Click"/>

                    <Button Grid.Column="2" Content="Enviar →"
                            Style="{StaticResource AresButton}"
                            Margin="6,0,0,0" Height="36"
                            VerticalAlignment="Bottom"
                            Click="Send_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
