<Window x:Class="AresAssistant.Views.ModelDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Descargando modelo"
        Width="480" Height="280"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder" CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5" Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c0c14" Offset="0"/>
                <GradientStop Color="#06060c" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="15"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="34" Opacity="0.55" Color="#ff2222"/>
        </Border.Effect>
        <Grid Margin="28,22,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="⬇" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="Descargando modelo" FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Model name -->
            <TextBlock x:Name="TxtModelName" Grid.Row="1"
                       FontSize="13" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas"
                       Margin="0,0,0,12"/>

            <!-- Progress bar -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Border Background="#111111" CornerRadius="5" Height="10"
                        BorderBrush="#1a1a1a" BorderThickness="1"/>
                <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                        CornerRadius="5" Height="10" Width="0"
                        Background="{DynamicResource AccentBrush}">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.6" Color="#ff2222"/>
                    </Border.Effect>
                </Border>
            </Grid>

            <!-- Percentage + size -->
            <Grid Grid.Row="3" Margin="0,0,0,6">
                <TextBlock x:Name="TxtPercentage" Text="0 %" FontSize="20" FontWeight="Bold"
                           Foreground="#ffffff" FontFamily="Consolas" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtSize" Text="" FontSize="11"
                           Foreground="#707070" FontFamily="Consolas"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Status text -->
            <TextBlock x:Name="TxtStatus" Grid.Row="4" Text="Conectando..."
                       FontSize="11" Foreground="#606060" FontFamily="Consolas"
                       TextWrapping="Wrap" Margin="0,0,0,4"/>

            <!-- Spacer -->
            <Border Grid.Row="5"/>

            <!-- Cancel button -->
            <Button x:Name="BtnCancel" Grid.Row="6" Content="Cancelar"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" Width="100"
                    Click="BtnCancel_Click"/>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="15" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
