<UserControl x:Class="AresAssistant.Views.FullHudModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1200" Height="800">

    <!-- Outer shell: futuristic glass with accent glow -->
    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="20"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Header spans all columns — glass gradient + bottom accent separator -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    CornerRadius="20,20,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1a141428" Offset="0"/>
                        <GradientStop Color="#0d0a0a14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Bottom accent separator line — brighter glass edge -->
                    <Rectangle VerticalAlignment="Bottom" Height="1" Margin="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00ff2222" Offset="0"/>
                                <GradientStop Color="#77ff2222" Offset="0.2"/>
                                <GradientStop Color="#ccff2222" Offset="0.5"/>
                                <GradientStop Color="#55ff2222" Offset="0.8"/>
                                <GradientStop Color="#00ff2222" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="18,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M 10,0 L 20,14 L 10,28 L 0,14 Z"
                                  Fill="{DynamicResource AccentBrush}" Width="20" Height="28"
                                  Margin="0,0,12,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="HudPulseDiamond">
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.58" To="1" Duration="0:0:0.65"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="HudPulseDiamond"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                                <Path.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.6" Color="#ff2222"/>
                                </Path.Effect>
                            </Path>
                            <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}" FontFamily="Consolas" FontSize="18"
                                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" — HUD COMPLETO"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="⊟" ToolTip="Modo overlay"
                                    Click="ToggleMode_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="⚙" ToolTip="Ajustes"
                                    Click="Settings_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="🗑" ToolTip="Limpiar chat"
                                    Click="ClearChat_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="✕" ToolTip="Cerrar"
                                    Click="Close_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ProgressBar Grid.Row="0" Grid.ColumnSpan="3"
                         Height="2"
                         VerticalAlignment="Bottom"
                         Margin="16,0,16,0"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="#1a1a2d"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Left panel: Tool list -->
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                    BorderBrush="#22222e" BorderThickness="0,0,1,0"
                    Padding="14,14,12,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1a0a0a12" Offset="0"/>
                        <GradientStop Color="#220d0d18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <!-- Section header with bottom accent line -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                        <TextBlock Text="HERRAMIENTAS" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Margin="0,0,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#88ff2222" Offset="0"/>
                                    <GradientStop Color="#00ff2222" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ToolNames.Count, StringFormat='{}{0} disponibles'}"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource SubtextBrush}" Margin="0,6,0,12"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="7,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GlassBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Center: Chat messages -->
            <TextBox Grid.Row="1" Grid.Column="1" Height="30" Margin="20,10,20,0"
                     VerticalAlignment="Top"
                     Style="{StaticResource AresTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Buscar en este chat"/>
            <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,44,20,14">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                        <Setter Property="Opacity" Value="0.2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding MessagesView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8,0,0" Loaded="MessageBubble_Loaded"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <Border MaxWidth="640" MinWidth="180" Padding="16,12">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem Header="Copiar" Tag="📋" Style="{StaticResource DarkMenuItem}" Click="CopyMessage_Click"/>
                                            <MenuItem Header="Leer en voz alta" Tag="🔊" Style="{StaticResource DarkMenuItem}" Click="SpeakMessage_Click"/>
                                            <MenuItem Header="Eliminar mensaje" Tag="🗑" Style="{StaticResource DarkMenuItem}" Click="DeleteMessage_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="18,18,18,5"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                    <Setter Property="BorderBrush" Value="#2a2a40"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#cc111120" Offset="0"/>
                                                                <GradientStop Color="#cc0d0d18" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="CornerRadius" Value="18,18,5,18"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#cc200a0a" Offset="0"/>
                                                                <GradientStop Color="#cc160606" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- ARES left accent bar + content -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Left accent bar — only for ARES messages -->
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Margin="0,0,10,0" VerticalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#ff2222" Offset="0"/>
                                                                <GradientStop Color="#661111" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <!-- Header: icon + role + timestamp -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- ARES diamond icon -->
                                                    <Path Data="M 4,0 L 8,6 L 4,12 L 0,6 Z"
                                                          Width="8" Height="12"
                                                          VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <!-- Role name -->
                                                    <TextBlock FontSize="11" FontFamily="Consolas"
                                                               FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ARES"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Text" Value="TÚ"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" VerticalAlignment="Center"
                                                        Margin="10,0,0,0" Padding="6,2"
                                                        CornerRadius="5" BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#121822"/>
                                                            <Setter Property="BorderBrush" Value="#2a3242"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Background" Value="#241010"/>
                                                                    <Setter Property="BorderBrush" Value="#4a1a1a"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#9fb0c8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Foreground" Value="#e0a5a5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                            <!-- Separator -->
                                            <Rectangle Height="1" Margin="-2,0,-2,9" Opacity="0.25">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Fill" Value="#22222e"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentGlowBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                            <!-- Content -->
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontSize="{DynamicResource FontSizeNormal}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       LineHeight="23" MaxWidth="590"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Right panel: Personal dashboard -->
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="2"
                    BorderBrush="#22222e" BorderThickness="1,0,0,0"
                    Padding="14,14,14,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                        <GradientStop Color="#1a0a0a12" Offset="0"/>
                        <GradientStop Color="#220d0d18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Top" Text="DASHBOARD" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Margin="0,0,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#88ff2222" Offset="0"/>
                                    <GradientStop Color="#00ff2222" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="{Binding DashboardClock}" FontSize="11"
                                   FontFamily="Consolas" Foreground="{DynamicResource TextBrush}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding ActiveContextProfileText}" FontSize="10"
                                   FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding StatusText, FallbackValue='Esperando...'}"
                                   FontSize="10" FontFamily="Consolas"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsInitializingModules}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Visibility="{Binding WidgetWeatherEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CLIMA" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                        <Border Grid.Column="1" CornerRadius="8" Padding="6,2" Margin="8,0,0,0"
                                                Background="#1a2b3d" BorderBrush="#2f5678" BorderThickness="1"
                                                Visibility="{Binding WeatherIsCached, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding WeatherCacheBadgeText}" FontSize="9" FontFamily="Consolas" Foreground="#9dd4ff"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding WeatherText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                               FontSize="11" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding WidgetWorldClockEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="HORA MUNDIAL" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="{Binding WorldClockNy}" Margin="0,4,0,0" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding WorldClockTokyo}" Margin="0,2,0,0" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding WidgetSystemLiveEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="SISTEMA EN VIVO" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="{Binding CpuText}" Margin="0,4,0,0" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding RamText}" Margin="0,2,0,0" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding WidgetTasksEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PRÓXIMAS TAREAS" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                    <ItemsControl ItemsSource="{Binding UpcomingTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Label}" FontSize="10" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="{Binding InText}" FontSize="9" Foreground="{DynamicResource SubtextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Time}" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding WidgetProductivityEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="PRODUCTIVIDAD" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Grid.Column="1" Content="Resumen IA" Height="24" Padding="8,0" Margin="6,0,0,0"
                                                Style="{StaticResource GhostButton}" Click="RefreshProductivitySummary_Click"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ProductivityApps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,7,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding AppName}" FontSize="10" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding TimeText}" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource SubtextBrush}"/>
                                                    </Grid>
                                                    <ProgressBar Height="6" Maximum="100" Value="{Binding Percentage}" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding ShareText}" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="#120d0d15" BorderBrush="#2a2a3a" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding DailyProductivitySummary}" TextWrapping="Wrap" FontSize="10" Foreground="{DynamicResource SubtextBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Input row -->
            <Border Grid.Row="2" Grid.Column="1"
                    CornerRadius="0,0,20,20"
                    BorderBrush="#1a1a2e" BorderThickness="0,1,0,0"
                    Padding="14,11,14,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#14141e" Offset="0"/>
                        <GradientStop Color="#0a0a14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Unified input container — glass style -->
                <Border x:Name="HudInputContainer"
                        Background="{DynamicResource GlassBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1" CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Effect" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="InputBox"
                                     Style="{StaticResource AresTextBox}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="2,8,8,8"
                                     TextAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="Input_KeyDown"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     MinHeight="38" MaxHeight="120"
                                     VerticalAlignment="Stretch"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="4000"/>
                            <TextBlock Text="Escribe un mensaje..."
                                       IsHitTestVisible="False"
                                       Margin="3,10,0,0"
                                       VerticalAlignment="Top"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontStyle="Italic"
                                       FontSize="{DynamicResource FontSizeNormal}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=InputBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=InputBox}" Value="{x:Null}"/>
                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="Exportar"
                                Style="{StaticResource GhostButton}"
                                BorderThickness="0"
                                Margin="4,0,0,0" Height="34"
                                VerticalAlignment="Center"
                                Click="Export_Click"/>
                        <Button Grid.Column="2"
                            Style="{StaticResource GhostButton}"
                            Margin="4,0,0,0" Height="34" Width="34"
                            Padding="0" ToolTip="Adjuntar captura al próximo mensaje"
                            VerticalAlignment="Center"
                            Click="AttachScreen_Click">
                            <TextBlock Text="◇" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="3"
                            Style="{StaticResource GhostButton}"
                            Margin="4,0,0,0" Height="34" Width="34"
                            Padding="0" ToolTip="Cancelar respuesta"
                            VerticalAlignment="Center"
                            Click="CancelResponse_Click"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="■" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                        </Button>
                        <Button Grid.Column="4"
                                Style="{StaticResource AresButton}"
                                Margin="6,0,4,0" Height="34" Width="42"
                                Padding="0"
                                VerticalAlignment="Center"
                                Click="Send_Click"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">
                            <Viewbox Width="15" Height="15" Stretch="Uniform">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M2,8 L12.2,8 M8.6,4.4 L12.2,8 L8.6,11.6"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <Button.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#ff2222"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
