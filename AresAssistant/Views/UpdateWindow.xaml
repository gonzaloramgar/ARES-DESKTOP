<Window x:Class="AresAssistant.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Actualización disponible"
        Width="480" Height="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border CornerRadius="12"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5" Opacity="0"
            x:Name="RootBorder">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c0c14" Offset="0"/>
                <GradientStop Color="#06060c" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="15"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="34" Opacity="0.55" Color="#ff2222"/>
        </Border.Effect>
        <Grid Margin="28,22,28,22">

            <!-- ── Panel info (estado inicial) ── -->
            <Grid x:Name="PanelInfo">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="↑" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Nueva versión disponible" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="TxtVersion" Grid.Row="1"
                           FontSize="13" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas"
                           Margin="0,0,0,10"/>

                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <TextBlock x:Name="TxtNotes"
                               FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas"
                               TextWrapping="Wrap" MaxHeight="80"/>
                </Border>

                <Border Grid.Row="3"/>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnLater" Content="Más tarde"
                            Style="{StaticResource GhostButton}"
                            Width="100" Margin="0,0,8,0"
                            Click="BtnLater_Click"/>
                    <Button x:Name="BtnUpdate" Content="Actualizar"
                            Style="{StaticResource AresButton}"
                            Width="110"
                            Click="BtnUpdate_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── Panel progreso (descarga) ── -->
            <Grid x:Name="PanelProgress" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="⬇" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Actualizando ARES" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="TxtStep" Grid.Row="1"
                           Text="Preparando descarga..."
                           FontSize="13" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas"
                           Margin="0,0,0,12"/>

                <Grid x:Name="ProgressBarGrid" Grid.Row="2" Margin="0,0,0,8">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="5" Height="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                    <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                            CornerRadius="5" Height="10" Width="0"
                            Background="{DynamicResource AccentBrush}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.6" Color="#ff2222"/>
                        </Border.Effect>
                    </Border>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,6">
                    <TextBlock x:Name="TxtPercentage" Text="0 %" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtSize" Text="" FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>

                <TextBlock x:Name="TxtStatus" Grid.Row="4"
                           FontSize="11" Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <Border Grid.Row="5"/>

                <Button x:Name="BtnCancel" Grid.Row="6" Content="Cancelar"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Width="100"
                        Click="BtnCancel_Click"/>
            </Grid>

        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="15" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
