<UserControl x:Class="AresAssistant.Views.FullHudModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1200" Height="800">

    <!-- Outer shell: 1.5px border, prominent accent glow -->
    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="14"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.4" Color="#ff2222"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Header spans all columns — glass gradient + bottom accent separator -->
            <Border Grid.Row="0" Grid.ColumnSpan="3"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#13131f" Offset="0"/>
                        <GradientStop Color="#0a0a14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Bottom accent separator line -->
                    <Rectangle VerticalAlignment="Bottom" Height="1.5" Margin="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00ff2222" Offset="0"/>
                                <GradientStop Color="#66ff2222" Offset="0.25"/>
                                <GradientStop Color="#99ff2222" Offset="0.5"/>
                                <GradientStop Color="#44ff2222" Offset="0.75"/>
                                <GradientStop Color="#00ff2222" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="18,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M 10,0 L 20,14 L 10,28 L 0,14 Z"
                                  Fill="{DynamicResource AccentBrush}" Width="20" Height="28"
                                  Margin="0,0,12,0">
                                <Path.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.6" Color="#ff2222"/>
                                </Path.Effect>
                            </Path>
                            <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}" FontFamily="Consolas" FontSize="18"
                                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" — HUD COMPLETO"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#3a3a52" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="⊟" ToolTip="Modo overlay"
                                    Click="ToggleMode_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="⚙" ToolTip="Ajustes"
                                    Click="Settings_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="🗑" ToolTip="Limpiar chat"
                                    Click="ClearChat_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16" Margin="0,0,4,0"/>
                            <Button Content="✕" ToolTip="Cerrar"
                                    Click="Close_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="32" Height="32" Padding="0" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Left panel: Tool list -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                    BorderBrush="#18181f" BorderThickness="0,0,1,0"
                    Padding="14,14,12,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0a0a12" Offset="0"/>
                        <GradientStop Color="#0d0d16" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <!-- Section header with bottom accent line -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                        <TextBlock Text="HERRAMIENTAS" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Margin="0,0,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#88ff2222" Offset="0"/>
                                    <GradientStop Color="#00ff2222" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding ToolNames.Count, StringFormat='{}{0} disponibles'}"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="#3a3a52" Margin="0,6,0,12"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="7,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#131320"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   FontFamily="Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#484860"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Foreground" Value="#8888a0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Center: Chat messages -->
            <ScrollViewer Grid.Row="1" Grid.Column="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,14">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8,0,0" Loaded="MessageBubble_Loaded"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <Border MaxWidth="640" MinWidth="180" Padding="16,12">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem Header="Copiar" Tag="📋" Style="{StaticResource DarkMenuItem}" Click="CopyMessage_Click"/>
                                            <MenuItem Header="Leer en voz alta" Tag="🔊" Style="{StaticResource DarkMenuItem}" Click="SpeakMessage_Click"/>
                                            <MenuItem Header="Eliminar mensaje" Tag="🗑" Style="{StaticResource DarkMenuItem}" Click="DeleteMessage_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="16,16,16,4"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                    <Setter Property="BorderBrush" Value="#1e1e2e"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#111120" Offset="0"/>
                                                                <GradientStop Color="#0d0d18" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="CornerRadius" Value="16,16,4,16"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#200a0a" Offset="0"/>
                                                                <GradientStop Color="#160606" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- ARES left accent bar + content -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Left accent bar — only for ARES messages -->
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Margin="0,0,10,0" VerticalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#ff2222" Offset="0"/>
                                                                <GradientStop Color="#661111" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <!-- Header: icon + role + timestamp -->
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- ARES diamond icon -->
                                                    <Path Data="M 4,0 L 8,6 L 4,12 L 0,6 Z"
                                                          Width="8" Height="12"
                                                          VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <!-- User dot -->
                                                    <Ellipse Width="10" Height="10"
                                                             VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <!-- Role name -->
                                                    <TextBlock FontSize="11" FontFamily="Consolas"
                                                               FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ARES"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Text" Value="TÚ"/>
                                                                        <Setter Property="Foreground" Value="#686880"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                                           FontSize="9" FontFamily="Consolas" Foreground="#3a3a50"/>
                                            </Grid>
                                            <!-- Separator -->
                                            <Rectangle Height="1" Margin="-2,0,-2,9" Opacity="0.25">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Fill" Value="#22222e"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentGlowBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                            <!-- Content -->
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontSize="{DynamicResource FontSizeNormal}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       LineHeight="23" MaxWidth="590"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Right panel: System status -->
            <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
                    BorderBrush="#18181f" BorderThickness="1,0,0,0"
                    Padding="14,14,14,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                        <GradientStop Color="#0a0a12" Offset="0"/>
                        <GradientStop Color="#0d0d16" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <!-- Section header with bottom accent line -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Top" Text="ESTADO" FontSize="10"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Rectangle Height="1" Margin="0,0,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#88ff2222" Offset="0"/>
                                    <GradientStop Color="#00ff2222" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <TextBlock x:Name="SystemStatus"
                               Text="{Binding StatusText, FallbackValue='Esperando...'}"
                               FontSize="11" DockPanel.Dock="Top"
                               FontFamily="Consolas" Foreground="#686880"
                               TextWrapping="Wrap" Margin="0,10,0,0"/>
                </DockPanel>
            </Border>

            <!-- Status bar / Thinking indicator -->
            <Grid Grid.Row="2" Grid.Column="1" Height="28" Margin="0">
                <Border Background="#09090f" BorderBrush="#15151f" BorderThickness="0,1,0,0">
                    <Grid Margin="16,0">
                        <!-- Left accent indicator bar -->
                        <Rectangle Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                   Margin="0" Fill="{DynamicResource AccentBrush}" Opacity="0.45"/>
                        <!-- Status text when idle -->
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="11" FontStyle="Italic" VerticalAlignment="Center"
                                   Margin="10,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Spinning arc when thinking -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="10,0,0,0"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Canvas Width="18" Height="18" VerticalAlignment="Center">
                                <Canvas.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="HudSpinArc"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    From="0" To="360" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Canvas.Triggers>
                                <Ellipse Width="18" Height="18"
                                         Stroke="#1e1e2e" StrokeThickness="2.5" Fill="Transparent"/>
                                <Path x:Name="HudSpinArc"
                                      Data="M 9,1.5 A 7.5,7.5 0 1 1 1.5,9"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.RenderTransform>
                                        <RotateTransform CenterX="9" CenterY="9"/>
                                    </Path.RenderTransform>
                                    <Path.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.7" Color="#ff2222"/>
                                    </Path.Effect>
                                </Path>
                            </Canvas>
                            <TextBlock Text="Pensando" Margin="8,0,0,0"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center" FontStyle="Italic"/>
                            <!-- Animated dots -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="1,2,0,0">
                                <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Margin="0,0,2.5,0" Opacity="0.15">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0"/>
                                        </Storyboard></BeginStoryboard></EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Margin="0,0,2.5,0" Opacity="0.15">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.15"/>
                                        </Storyboard></BeginStoryboard></EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="3.5" Height="3.5" Fill="{DynamicResource SubtextBrush}" Opacity="0.15">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.12" To="0.85" Duration="0:0:0.45" AutoReverse="True" BeginTime="0:0:0.3"/>
                                        </Storyboard></BeginStoryboard></EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Input row -->
            <Border Grid.Row="3" Grid.Column="1"
                    BorderBrush="#15151f" BorderThickness="0,1,0,0"
                    Padding="14,11,14,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0a0a12" Offset="0"/>
                        <GradientStop Color="#07070f" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Unified input container -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="InputBox"
                                     Style="{StaticResource AresTextBox}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="Input_KeyDown"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     MinHeight="38" MaxHeight="120"
                                     VerticalAlignment="Stretch"
                                     VerticalScrollBarVisibility="Auto"
                                     MaxLength="4000"/>
                            <TextBlock Text="Escribe un mensaje..."
                                       IsHitTestVisible="False"
                                       Margin="12,10,0,0"
                                       VerticalAlignment="Top"
                                       Foreground="#3a3a52"
                                       FontStyle="Italic"
                                       FontSize="{DynamicResource FontSizeNormal}"
                                       Visibility="{Binding InputText, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </Grid>
                        <Button Grid.Column="1" Content="Exportar"
                                Style="{StaticResource GhostButton}"
                                BorderThickness="0"
                                Margin="4,0,0,0" Height="34"
                                VerticalAlignment="Center"
                                Click="Export_Click"/>
                        <Button Grid.Column="2" Content="Enviar →"
                                Style="{StaticResource AresButton}"
                                Margin="6,0,4,0" Height="34"
                                VerticalAlignment="Center"
                                Click="Send_Click"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">
                            <Button.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#ff2222"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
