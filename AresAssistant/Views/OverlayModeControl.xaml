<UserControl x:Class="AresAssistant.Views.OverlayModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380" Height="600">

    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="10"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>     <!-- Header -->
                <RowDefinition Height="*"/>       <!-- Chat -->
                <RowDefinition Height="Auto"/>    <!-- Status -->
                <RowDefinition Height="Auto"/>    <!-- Input -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0a0a0a" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Diamond logo mini -->
                        <Path Data="M 8,0 L 16,11 L 8,22 L 0,11 Z"
                              Fill="{DynamicResource AccentBrush}" Width="16" Height="22"
                              Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}"
                                   FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button ToolTip="Cambiar a modo HUD completo"
                                Click="ToggleMode_Click"
                                Style="{DynamicResource GhostButton}"
                                Height="26" Padding="6,0" FontSize="11" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⊞" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="HUD" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtextBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Content="⚙" ToolTip="Ajustes"
                                Click="Settings_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="28" Height="28" Padding="0" FontSize="14" Margin="0,0,4,0"/>
                        <Button Content="✕" ToolTip="Cerrar"
                                Click="Close_Click"
                                Style="{DynamicResource GhostButton}"
                                Width="28" Height="28" Padding="0" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chat messages -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,8">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4"
                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}"
                                    MaxWidth="300">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1a1a1a"/>
                                        <Setter Property="CornerRadius" Value="8,8,8,2"/>
                                        <Setter Property="Padding" Value="10,7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                <Setter Property="Background" Value="#2a1010"/>
                                                <Setter Property="CornerRadius" Value="8,8,2,8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           FontSize="{DynamicResource FontSizeNormal}"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Status -->
            <TextBlock Grid.Row="2" Text="{Binding StatusText}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="11" Margin="14,2" FontStyle="Italic"/>

            <!-- Input row -->
            <Border Grid.Row="3" Background="#0a0a0a" CornerRadius="0,0,10,10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="InputBox"
                             Style="{StaticResource AresTextBox}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Input_KeyDown"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             MinHeight="36" MaxHeight="120"
                             VerticalAlignment="Stretch"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="4000"/>

                    <Button Grid.Column="1" Content="→"
                            Style="{StaticResource AresButton}"
                            Width="38" Height="34" Margin="6,0,0,0"
                            FontSize="16"
                            VerticalAlignment="Bottom"
                            Click="Send_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
