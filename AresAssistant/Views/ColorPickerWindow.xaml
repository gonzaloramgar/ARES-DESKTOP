<Window x:Class="AresAssistant.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color" Height="530" Width="302"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="ColorSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid Width="20" Height="20">
                                                <Ellipse Fill="#111111" Stroke="White" StrokeThickness="2.5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="1" Color="White"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="20" BorderThickness="1"
            BorderBrush="{DynamicResource AccentBrush}" Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c0c14" Offset="0"/>
                <GradientStop Color="#06060c" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="15"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="45" Opacity="0.7" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="18,16,18,18">

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="2.5" Height="12" RadiusX="1" RadiusY="1"
                               Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="SELECTOR DE COLOR" FontFamily="Consolas" FontSize="10"
                               FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{DynamicResource GhostButton}" Width="24" Height="24"
                        Padding="0" FontSize="11" Click="Cancel_Click"/>
            </Grid>

            <!-- Live color preview -->
            <Border x:Name="PreviewBorder" Height="66" CornerRadius="14" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect x:Name="PreviewGlow" ShadowDepth="0" BlurRadius="24" Opacity="0.8" Color="#ff2222"/>
                </Border.Effect>
                <Grid>
                    <TextBlock x:Name="PreviewHex"
                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                               Foreground="#FFFFFFCC"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.9" Color="Black"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- R G B channel display -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource GlassBrush}" CornerRadius="10"
                        Padding="0,7" Margin="0,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="R" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                   Foreground="#ff4444" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="RLabel" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource GlassBrush}" CornerRadius="10"
                        Padding="0,7" Margin="3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="G" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                   Foreground="#44ff88" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="GLabel" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource GlassBrush}" CornerRadius="10"
                        Padding="0,7" Margin="3,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="B" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                   Foreground="#4499ff" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="BLabel" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Hue strip -->
            <TextBlock Text="MATIZ" FontFamily="Consolas" FontSize="8"
                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
            <Grid Height="30" Margin="0,0,0,12">
                <Border CornerRadius="7" Height="14" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0000" Offset="0"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Slider x:Name="HueSlider" Style="{StaticResource ColorSlider}"
                        Minimum="0" Maximum="360" Value="0"
                        VerticalAlignment="Center"
                        ValueChanged="Slider_ValueChanged"/>
            </Grid>

            <!-- Saturation strip -->
            <TextBlock Text="SATURACIÓN" FontFamily="Consolas" FontSize="8"
                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
            <Grid Height="30" Margin="0,0,0,12">
                <Border x:Name="SatTrackBg" CornerRadius="7" Height="14" VerticalAlignment="Center"/>
                <Slider x:Name="SatSlider" Style="{StaticResource ColorSlider}"
                        Minimum="0" Maximum="100" Value="100"
                        VerticalAlignment="Center"
                        ValueChanged="Slider_ValueChanged"/>
            </Grid>

            <!-- Brightness strip -->
            <TextBlock Text="BRILLO" FontFamily="Consolas" FontSize="8"
                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
            <Grid Height="30" Margin="0,0,0,16">
                <Border x:Name="ValTrackBg" CornerRadius="7" Height="14" VerticalAlignment="Center"/>
                <Slider x:Name="ValSlider" Style="{StaticResource ColorSlider}"
                        Minimum="0" Maximum="100" Value="100"
                        VerticalAlignment="Center"
                        ValueChanged="Slider_ValueChanged"/>
            </Grid>

            <!-- Hex input -->
            <TextBox x:Name="HexBox" Style="{StaticResource AresTextBox}"
                     FontFamily="Consolas" FontSize="14" FontWeight="Bold" MaxLength="7"
                     HorizontalContentAlignment="Center"
                     TextChanged="HexBox_TextChanged"
                     Margin="0,0,0,14"/>

            <!-- Preset palette -->
            <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                <Button Tag="#ff2222" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#ff2222">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#ff2222" Stroke="Transparent" StrokeThickness="2.5"><Ellipse.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="0" Opacity="0" Color="#ff2222"/></Ellipse.Effect></Ellipse><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#ff6600" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#ff6600">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#ff6600" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#ffcc00" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#ffcc00">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#ffcc00" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#22dd55" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#22dd55">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#22dd55" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#00aaff" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#00aaff">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#00aaff" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#8855ff" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#8855ff">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#8855ff" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#ff44cc" Click="Preset_Click" Width="28" Height="28" Margin="0,0,3,0" Cursor="Hand" ToolTip="#ff44cc">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#ff44cc" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Tag="#aaaaaa" Click="Preset_Click" Width="28" Height="28" Cursor="Hand" ToolTip="#aaaaaa">
                    <Button.Template><ControlTemplate TargetType="Button"><Ellipse x:Name="E" Width="22" Height="22" Fill="#aaaaaa" Stroke="Transparent" StrokeThickness="2.5"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="E" Property="Stroke" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
            </WrapPanel>

            <!-- Footer -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancelar" Style="{DynamicResource GhostButton}"
                        Height="34" Margin="0,0,5,0" Click="Cancel_Click"/>
                <Button Grid.Column="1" Content="Aplicar" Style="{DynamicResource AresButton}"
                        Height="34" Margin="5,0,0,0" Click="Apply_Click"/>
            </Grid>

        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="15" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
