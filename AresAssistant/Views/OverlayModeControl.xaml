<UserControl x:Class="AresAssistant.Views.OverlayModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380" Height="600">

    <!-- Outer shell: futuristic glass with accent glow -->
    <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="20"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header — glass gradient with bottom accent separator -->
            <Border Grid.Row="0" CornerRadius="20,20,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1a141428" Offset="0"/>
                        <GradientStop Color="#0d0a0a14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Bottom accent separator line — brighter glass edge -->
                    <Rectangle VerticalAlignment="Bottom" Height="1" Margin="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00ff2222" Offset="0"/>
                                <GradientStop Color="#99ff2222" Offset="0.3"/>
                                <GradientStop Color="#ccff2222" Offset="0.5"/>
                                <GradientStop Color="#66ff2222" Offset="0.75"/>
                                <GradientStop Color="#00ff2222" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Margin="14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Diamond logo -->
                            <Path x:Name="OverlayHeaderDiamond" Data="M 8,0 L 16,11 L 8,22 L 0,11 Z"
                                  Fill="{DynamicResource AccentBrush}" Width="16" Height="22"
                                  Margin="0,0,9,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="OverlayPulseDiamond">
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.6" To="1" Duration="0:0:0.65"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="OverlayPulseDiamond"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                                <Path.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.6" Color="#ff2222"/>
                                </Path.Effect>
                            </Path>
                            <TextBlock Text="{Binding AssistantName, FallbackValue='ARES'}"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button ToolTip="Cambiar a modo HUD completo"
                                    Click="ToggleMode_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Height="26" Padding="7,0" FontSize="11" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⊞" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="HUD" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Content="⚙" ToolTip="Ajustes"
                                    Click="Settings_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="28" Height="28" Padding="0" FontSize="14" Margin="0,0,4,0"/>
                            <Button Content="✕" ToolTip="Cerrar"
                                    Click="Close_Click"
                                    Style="{DynamicResource GhostButton}"
                                    Width="28" Height="28" Padding="0" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ProgressBar Grid.Row="0"
                         Height="2"
                         VerticalAlignment="Bottom"
                         Margin="10,0,10,0"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="#1a1a2e"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Chat messages -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,10,14,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
                        <Setter Property="Opacity" Value="0.2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding MessagesView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8,0,0" Loaded="MessageBubble_Loaded"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignConverter}}">
                                <Border MaxWidth="316" MinWidth="140" Margin="4,0">
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem Header="Copiar" Tag="📋" Style="{StaticResource DarkMenuItem}" Click="CopyMessage_Click"/>
                                            <MenuItem Header="Leer en voz alta" Tag="🔊" Style="{StaticResource DarkMenuItem}" Click="SpeakMessage_Click"/>
                                            <MenuItem Header="Eliminar mensaje" Tag="🗑" Style="{StaticResource DarkMenuItem}" Click="DeleteMessage_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="18,18,18,5"/>
                                            <Setter Property="Padding" Value="13,10"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                    <Setter Property="BorderBrush" Value="#2a2a40"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#cc111120" Offset="0"/>
                                                                <GradientStop Color="#cc0d0d18" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="CornerRadius" Value="18,18,5,18"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#cc200a0a" Offset="0"/>
                                                                <GradientStop Color="#cc160606" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <!-- ARES left accent bar -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Left accent bar — only for ARES messages -->
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Margin="0,0,9,0" VerticalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#ff2222" Offset="0"/>
                                                                <GradientStop Color="#661111" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <!-- Header: icon + role + timestamp -->
                                            <Grid Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- ARES diamond icon -->
                                                    <Path Data="M 3,0 L 6,5 L 3,10 L 0,5 Z"
                                                          Width="6" Height="10"
                                                          VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <!-- Role name -->
                                                    <TextBlock FontSize="10" FontFamily="Consolas"
                                                               FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ARES"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Text" Value="TÚ"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" VerticalAlignment="Center"
                                                        Margin="8,0,0,0" Padding="6,2"
                                                        CornerRadius="5" BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#121822"/>
                                                            <Setter Property="BorderBrush" Value="#2a3242"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Background" Value="#241010"/>
                                                                    <Setter Property="BorderBrush" Value="#4a1a1a"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#9fb0c8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                        <Setter Property="Foreground" Value="#e0a5a5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                            <!-- Content -->
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontSize="{DynamicResource FontSizeNormal}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       LineHeight="21"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Status / Thinking indicator — with left accent indicator bar -->
            <Grid Grid.Row="2" Height="26">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IsInitializingModules}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="Transparent" BorderBrush="#221515" BorderThickness="0,1,0,0">
                    <!-- Status text when idle -->
                    <Grid>
                        <!-- Left accent indicator bar -->
                        <Rectangle Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                   Margin="0" Fill="{DynamicResource AccentBrush}" Opacity="0.5"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="11" FontStyle="Italic"
                                   Margin="14,0,14,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ProgressBar Height="3" Margin="14,0,14,0"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="#1c1f2d"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Input row — pill input, wider send button -->
            <Border Grid.Row="3" CornerRadius="0,0,20,20"
                    BorderBrush="#1a1a2e" BorderThickness="0,1,0,0"
                    Padding="12,10,12,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#14141e" Offset="0"/>
                        <GradientStop Color="#0a0a14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Unified input container — glass style -->
                    <Border
                            x:Name="InputContainer"
                            Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1" CornerRadius="14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentGlowBrush}"/>
                                    </Trigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=InputBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="InputBox"
                                         Style="{StaticResource AresTextBox}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="2,8,8,8"
                                         TextAlignment="Left"
                                         HorizontalContentAlignment="Left"
                                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="Input_KeyDown"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="False"
                                         MinHeight="38" MaxHeight="120"
                                         VerticalAlignment="Stretch"
                                         VerticalScrollBarVisibility="Auto"
                                         MaxLength="4000"/>
                                <TextBlock Text="Escribe un mensaje..."
                                           IsHitTestVisible="False"
                                           Margin="3,10,0,0"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontStyle="Italic"
                                           FontSize="{DynamicResource FontSizeNormal}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=InputBox}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=InputBox}" Value="{x:Null}"/>
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=InputBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Width="34" Height="34" Margin="4,0,0,0"
                                    Padding="0"
                                    ToolTip="Adjuntar captura al próximo mensaje"
                                    VerticalAlignment="Center"
                                    Click="AttachScreen_Click">
                                <TextBlock Text="◇" FontSize="12"/>
                            </Button>
                            <Button Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Width="34" Height="34" Margin="4,0,0,0"
                                    Padding="0"
                                    ToolTip="Cancelar respuesta"
                                    VerticalAlignment="Center"
                                    Click="CancelResponse_Click"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="■" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                            <Button Grid.Column="3"
                                    Style="{StaticResource AresButton}"
                                    Width="34" Height="34" Margin="6,0,4,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Click="Send_Click"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">
                                <Viewbox Width="14" Height="14" Stretch="Uniform">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="M2,8 L12.2,8 M8.6,4.4 L12.2,8 L8.6,11.6"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                                <Button.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#ff2222"/>
                                </Button.Effect>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
