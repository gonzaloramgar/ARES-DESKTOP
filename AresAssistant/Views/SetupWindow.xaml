<Window x:Class="AresAssistant.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Setup"
        Width="560" Height="720"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder"
            CornerRadius="14"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
            Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0f0f0f" Offset="0"/>
                <GradientStop Color="#070707" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="30"/>
        </Border.RenderTransform>

        <Grid Margin="0">
            <!-- Horizontal accent glow at top -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="14,14,0,0"
                    Margin="80,0" Opacity="0.8" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="{Binding AccentMediaColor}" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel HorizontalAlignment="Center" Margin="40,32,40,28">

                    <!-- ══════════  Mini ARES Logo  ══════════ -->
                    <Canvas Width="90" Height="90" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <!-- Outer glow ring -->
                        <Ellipse Width="84" Height="84" Canvas.Left="3" Canvas.Top="3"
                                 Stroke="{DynamicResource AccentGlowBrush}" StrokeThickness="5"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Ring1Scale" ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!-- Inner ring -->
                        <Ellipse Width="52" Height="52" Canvas.Left="19" Canvas.Top="19"
                                 Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" Opacity="0.45"/>
                        <!-- Diamond (rotates) -->
                        <Path Canvas.Left="31" Canvas.Top="23"
                              Fill="Transparent"
                              Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.2" Opacity="0.55"
                              Data="M 14,0 L 28,22 L 14,44 L 0,22 Z">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="DiamondRotate" Angle="0" CenterX="14" CenterY="22"/>
                            </Path.RenderTransform>
                        </Path>
                        <!-- Center dot -->
                        <Ellipse Width="5" Height="5" Canvas.Left="42.5" Canvas.Top="42.5"
                                 Fill="{DynamicResource AccentBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#ff2222" BlurRadius="6" ShadowDepth="0" Opacity="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>

                    <!-- Welcome Title -->
                    <TextBlock Text="BIENVENIDO A ARES" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,0,0,2">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#ff2222" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="Personaliza tu asistente antes de comenzar"
                               FontSize="11" Foreground="#555555" HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,0,0,28"/>

                    <!-- ══════════  COLOR DE ACENTO  ══════════ -->
                    <Border Background="#0b0b0b" CornerRadius="8"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="COLOR DE ACENTO" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Live preview bar -->
                            <Border x:Name="ColorPreview" Height="36" CornerRadius="6" Margin="0,0,0,10"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.35" Color="#000000"/>
                                </Border.Effect>
                                <TextBlock x:Name="ColorHexText" Text="#ff2222" FontFamily="Consolas" FontSize="11"
                                           Foreground="#FFFFFFBB" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>

                            <!-- Color swatches -->
                            <WrapPanel HorizontalAlignment="Center">
                                <Button Tag="#ff2222" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Rojo">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#ff2222"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#ff6600" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Naranja">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#ff6600"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#ffcc00" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Dorado">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#ffcc00"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#22dd55" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Verde">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#22dd55"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#00aaff" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Azul">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#00aaff"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#8855ff" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Violeta">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#8855ff"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#ff44cc" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Rosa">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#ff44cc"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#00ddc8" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Turquesa">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#00ddc8"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Tag="#aaaaaa" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Plata">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/>
                                                <Ellipse x:Name="Dot" Width="24" Height="24" Fill="#aaaaaa"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ══════════  PERSONALIDAD  ══════════ -->
                    <Border Background="#0b0b0b" CornerRadius="8"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="PERSONALIDAD" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Personality cards grid -->
                            <UniformGrid Columns="2" Rows="2">
                                <Border x:Name="CardFormal" Tag="formal"
                                        Background="#111111" CornerRadius="8"
                                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                                        Margin="0,0,5,5" Padding="12,10" Cursor="Hand"
                                        MouseLeftButtonDown="Personality_Click">
                                    <StackPanel>
                                        <TextBlock Text="🎩" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Formal" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Profesional y preciso" FontSize="9"
                                                   Foreground="#666666" HorizontalAlignment="Center"
                                                   FontFamily="Consolas" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CardCasual" Tag="casual"
                                        Background="#111111" CornerRadius="8"
                                        BorderBrush="#1e1e1e" BorderThickness="1.5"
                                        Margin="5,0,0,5" Padding="12,10" Cursor="Hand"
                                        MouseLeftButtonDown="Personality_Click">
                                    <StackPanel>
                                        <TextBlock Text="😎" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Casual" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Relajado y amigable" FontSize="9"
                                                   Foreground="#666666" HorizontalAlignment="Center"
                                                   FontFamily="Consolas" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CardSarcastico" Tag="sarcastico"
                                        Background="#111111" CornerRadius="8"
                                        BorderBrush="#1e1e1e" BorderThickness="1.5"
                                        Margin="0,5,5,0" Padding="12,10" Cursor="Hand"
                                        MouseLeftButtonDown="Personality_Click">
                                    <StackPanel>
                                        <TextBlock Text="😏" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Sarcástico" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Ingenioso y mordaz" FontSize="9"
                                                   Foreground="#666666" HorizontalAlignment="Center"
                                                   FontFamily="Consolas" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CardTecnico" Tag="tecnico"
                                        Background="#111111" CornerRadius="8"
                                        BorderBrush="#1e1e1e" BorderThickness="1.5"
                                        Margin="5,5,0,0" Padding="12,10" Cursor="Hand"
                                        MouseLeftButtonDown="Personality_Click">
                                    <StackPanel>
                                        <TextBlock Text="🔬" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Técnico" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Detallado y analítico" FontSize="9"
                                                   Foreground="#666666" HorizontalAlignment="Center"
                                                   FontFamily="Consolas" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- ══════════  NOMBRE DEL ASISTENTE  ══════════ -->
                    <Border Background="#0b0b0b" CornerRadius="8"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="NOMBRE DEL ASISTENTE" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="¿Cómo quieres que se llame tu IA?" FontSize="11"
                                       Foreground="#555555" FontFamily="Consolas" Margin="0,0,0,8"/>

                            <TextBox x:Name="NameBox" Style="{StaticResource AresTextBox}"
                                     Text="ARES" FontSize="14" FontFamily="Consolas"
                                     MaxLength="20"/>
                        </StackPanel>
                    </Border>

                    <!-- ══════════  COMENZAR  ══════════ -->
                    <Button x:Name="StartButton" Content="COMENZAR"
                            Style="{StaticResource AresButton}"
                            Click="Start_Click"
                            Width="220" Height="42"
                            FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                            HorizontalAlignment="Center" Cursor="Hand"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <!-- Entrance fade + slide -->
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="30" To="0" Duration="0:0:0.7">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
            <!-- Diamond rotation + ring pulse (forever) -->
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="DiamondRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:8"/>
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.9" To="1.08" Duration="0:0:2"
                                     AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.9" To="1.08" Duration="0:0:2"
                                     AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
