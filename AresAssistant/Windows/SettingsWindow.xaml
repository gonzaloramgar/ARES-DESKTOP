<Window x:Class="AresAssistant.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Ajustes"
        Width="600" Height="680"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="#0d0d0d" CornerRadius="10"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="54"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0a0a0a" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <TextBlock Text="AJUSTES" FontFamily="Consolas" FontSize="14"
                               FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{DynamicResource GhostButton}"
                            Click="Close_Click" Width="28" Height="28" Padding="0"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                <StackPanel>

                    <!-- Section: Apariencia -->
                    <TextBlock Text="APARIENCIA" FontFamily="Consolas" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                            <TextBlock Text="Color de acento" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AresTextBox}"
                                     Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                            <TextBlock Text="Tamaño de fuente" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <ComboBox Background="#1a1a1a" Foreground="{DynamicResource TextBrush}"
                                      SelectedValue="{Binding FontSize}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Pequeño" Tag="small"/>
                                <ComboBoxItem Content="Normal" Tag="medium"/>
                                <ComboBoxItem Content="Grande" Tag="large"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                            <TextBlock Text="Opacidad" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <Slider Minimum="0.3" Maximum="1.0"
                                    Value="{Binding OverlayOpacity}"
                                    Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                            <TextBlock Text="Posición del overlay" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <ComboBox Background="#1a1a1a" Foreground="{DynamicResource TextBrush}"
                                      SelectedValue="{Binding OverlayPosition}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Abajo-derecha" Tag="bottom-right"/>
                                <ComboBoxItem Content="Abajo-izquierda" Tag="bottom-left"/>
                                <ComboBoxItem Content="Arriba-derecha" Tag="top-right"/>
                                <ComboBoxItem Content="Arriba-izquierda" Tag="top-left"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Section: IA -->
                    <TextBlock Text="INTELIGENCIA ARTIFICIAL" FontFamily="Consolas" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                            <TextBlock Text="Modelo de Ollama" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <ComboBox Background="#1a1a1a" Foreground="{DynamicResource TextBrush}"
                                      Text="{Binding OllamaModel}"
                                      IsEditable="True"
                                      ItemsSource="{Binding AvailableModels}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                            <TextBlock Text="Nombre del asistente" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AresTextBox}"
                                     Text="{Binding AssistantName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                            <TextBlock Text="Personalidad" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <ComboBox Background="#1a1a1a" Foreground="{DynamicResource TextBrush}"
                                      SelectedValue="{Binding Personality}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Formal" Tag="formal"/>
                                <ComboBoxItem Content="Casual" Tag="casual"/>
                                <ComboBoxItem Content="Sarcástico" Tag="sarcastico"/>
                                <ComboBoxItem Content="Técnico" Tag="tecnico"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                            <TextBlock Text="Longitud de respuesta" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <ComboBox Background="#1a1a1a" Foreground="{DynamicResource TextBrush}"
                                      SelectedValue="{Binding ResponseLength}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Conciso" Tag="conciso"/>
                                <ComboBoxItem Content="Normal" Tag="normal"/>
                                <ComboBoxItem Content="Detallado" Tag="detallado"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Ollama status -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding OllamaStatus}" FontSize="12"
                                       Foreground="#888888" VerticalAlignment="Center"/>
                            <Button Content="Verificar conexión" Style="{StaticResource GhostButton}"
                                    Height="30" Click="CheckOllama_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Section: Teclas -->
                    <TextBlock Text="TECLAS RÁPIDAS" FontFamily="Consolas" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Mostrar/ocultar" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AresTextBox}"
                                     Text="{Binding ShowHideHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Cambiar modo" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AresTextBox}"
                                     Text="{Binding ToggleModeHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Section: Sistema -->
                    <TextBlock Text="SISTEMA" FontFamily="Consolas" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0"/>

                    <StackPanel>
                        <CheckBox Content="Iniciar con Windows"
                                  IsChecked="{Binding LaunchWithWindows}"
                                  Foreground="{DynamicResource TextBrush}"/>
                        <CheckBox Content="Guardar historial del chat"
                                  IsChecked="{Binding SaveChatHistory}"
                                  Foreground="{DynamicResource TextBrush}"/>

                        <Button Content="Reescanear sistema" Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Click="Rescan_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="#0a0a0a" CornerRadius="0,0,10,10" Padding="16,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Cancelar" Style="{StaticResource GhostButton}"
                            Width="90" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Content="Guardar" Style="{StaticResource AresButton}"
                            Width="90" Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
