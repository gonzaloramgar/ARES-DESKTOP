<Window x:Class="AresAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AresAssistant.Views"
        Title="ARES"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
    ShowInTaskbar="True"
    PreviewMouseLeftButtonDown="MainWindow_PreviewMouseLeftButtonDown">

    <Grid>
        <!-- Overlay mode control -->
        <controls:OverlayModeControl x:Name="OverlayControl"
                                     Visibility="Visible"/>

        <!-- Full HUD mode control -->
        <controls:FullHudModeControl x:Name="FullHudControl"
                                     Visibility="Collapsed"/>

    </Grid>
</Window>
