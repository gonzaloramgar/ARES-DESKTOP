<Window x:Class="AresAssistant.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Setup"
        Width="600" Height="700"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder"
            CornerRadius="16"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
            Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0f0f0f" Offset="0"/>
                <GradientStop Color="#060606" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="30"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Step indicator -->
                <RowDefinition Height="*"/>     <!-- Content pages -->
                <RowDefinition Height="Auto"/>  <!-- Navigation -->
            </Grid.RowDefinitions>

            <!-- Horizontal accent glow at top -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="16,16,0,0"
                    Margin="80,0" Opacity="0.8" IsHitTestVisible="False" Grid.RowSpan="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="{DynamicResource AccentMediaColor}" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ══════════  STEP INDICATOR  ══════════ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,16,0,6">
                <Ellipse x:Name="Dot0" Width="10" Height="10" Margin="4,0"
                         Fill="{DynamicResource AccentBrush}" Opacity="1"/>
                <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="4,0"
                         Fill="#333333" Opacity="0.5"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="4,0"
                         Fill="#333333" Opacity="0.5"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="4,0"
                         Fill="#333333" Opacity="0.5"/>
                <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="4,0"
                         Fill="#333333" Opacity="0.5"/>
                <Ellipse x:Name="Dot5" Width="8" Height="8" Margin="4,0"
                         Fill="#333333" Opacity="0.5"/>
            </StackPanel>

            <!-- ══════════  PAGE CONTAINER  ══════════ -->
            <Grid Grid.Row="1" ClipToBounds="True" Margin="0">

                <!-- ────── PAGE 0: Bienvenida + Nombre ────── -->
                <Grid x:Name="Page0" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,10,50,10">
                            <!-- ARES Logo -->
                            <Canvas Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Ellipse Width="94" Height="94" Canvas.Left="3" Canvas.Top="3"
                                         Stroke="{DynamicResource AccentGlowBrush}" StrokeThickness="5"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="Ring1Scale" ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="58" Height="58" Canvas.Left="21" Canvas.Top="21"
                                         Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" Opacity="0.45"/>
                                <Path Canvas.Left="35" Canvas.Top="26"
                                      Fill="Transparent"
                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.2" Opacity="0.55"
                                      Data="M 15,0 L 30,24 L 15,48 L 0,24 Z">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="DiamondRotate" Angle="0" CenterX="15" CenterY="24"/>
                                    </Path.RenderTransform>
                                </Path>
                                <Ellipse Width="6" Height="6" Canvas.Left="47" Canvas.Top="47"
                                         Fill="{DynamicResource AccentBrush}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#ff2222" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Canvas>

                            <TextBlock Text="BIENVENIDO A ARES" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,4">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#ff2222" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <TextBlock Text="Vamos a personalizar tu asistente paso a paso"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,30"/>

                            <!-- Name -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,18" Margin="0,0,0,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="NOMBRE DEL ASISTENTE" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="¿Cómo quieres que se llame tu IA?"
                                               FontSize="11" Foreground="#808080" FontFamily="Consolas" Margin="0,0,0,10"/>
                                    <TextBox x:Name="NameBox" Style="{StaticResource AresTextBox}"
                                             Text="ARES" FontSize="15" FontFamily="Consolas"
                                             MaxLength="20"/>
                                </StackPanel>
                            </Border>

                            <!-- Model -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,18">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="MODELO DE OLLAMA" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Modelo de IA que usará el asistente"
                                               FontSize="11" Foreground="#808080" FontFamily="Consolas" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="ModelBox" IsEditable="True" Text="qwen2.5:7b"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ────── PAGE 1: Apariencia ────── -->
                <Grid x:Name="Page1" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,14,50,10">
                            <TextBlock Text="🎨  APARIENCIA" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,6"/>
                            <TextBlock Text="Personaliza el aspecto de ARES"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,22"/>

                            <!-- Color -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="COLOR DE ACENTO" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Border x:Name="ColorPreview" Height="36" CornerRadius="6" Margin="0,0,0,10"
                                            Background="{DynamicResource AccentBrush}">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="18" Opacity="0.4" Color="#000"/>
                                        </Border.Effect>
                                        <TextBlock x:Name="ColorHexText" Text="#ff2222" FontFamily="Consolas" FontSize="11"
                                                   Foreground="#FFFFFFBB" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontWeight="Bold"/>
                                    </Border>
                                    <WrapPanel HorizontalAlignment="Center">
                                        <Button Tag="#ff2222" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Rojo"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#ff2222"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#ff6600" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Naranja"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#ff6600"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#ffcc00" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Dorado"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#ffcc00"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#22dd55" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Verde"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#22dd55"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#00aaff" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Azul"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#00aaff"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#8855ff" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Violeta"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#8855ff"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#ff44cc" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Rosa"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#ff44cc"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#00ddc8" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Turquesa"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#00ddc8"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                        <Button Tag="#aaaaaa" Click="Color_Click" Width="38" Height="38" Margin="3" Cursor="Hand" ToolTip="Plata"><Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Ring" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="24" Height="24" Fill="#aaaaaa"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Font Size + Opacity + Position -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Text="Tamaño de fuente" FontSize="11"
                                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                            <ComboBox x:Name="FontSizeBox" SelectedValuePath="Tag">
                                                <ComboBoxItem Content="Pequeño" Tag="small"/>
                                                <ComboBoxItem Content="Normal" Tag="medium" IsSelected="True"/>
                                                <ComboBoxItem Content="Grande" Tag="large"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <Grid Margin="0,0,0,5">
                                                <TextBlock Text="Opacidad" FontSize="11"
                                                           Foreground="{DynamicResource SubtextBrush}"/>
                                                <TextBlock x:Name="OpacityLabel" HorizontalAlignment="Right" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}" Text="85%"/>
                                            </Grid>
                                            <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" Value="0.85"
                                                    ValueChanged="Opacity_ValueChanged"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Posición del overlay" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="PositionBox" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Abajo — derecha" Tag="bottom-right" IsSelected="True"/>
                                        <ComboBoxItem Content="Abajo — izquierda" Tag="bottom-left"/>
                                        <ComboBoxItem Content="Arriba — derecha" Tag="top-right"/>
                                        <ComboBoxItem Content="Arriba — izquierda" Tag="top-left"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ────── PAGE 2: Inteligencia Artificial ────── -->
                <Grid x:Name="Page2" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,14,50,10">
                            <TextBlock Text="🤖  INTELIGENCIA ARTIFICIAL" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,6"/>
                            <TextBlock Text="Define cómo se comporta tu asistente"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,22"/>

                            <!-- Personality Cards -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="PERSONALIDAD" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <UniformGrid Columns="2" Rows="2">
                                        <Border x:Name="CardFormal" Tag="formal"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                                                Margin="0,0,5,5" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="Personality_Click">
                                            <StackPanel>
                                                <TextBlock Text="🎩" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Formal" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Profesional y preciso" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="CardCasual" Tag="casual"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="#1e1e1e" BorderThickness="1.5"
                                                Margin="5,0,0,5" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="Personality_Click">
                                            <StackPanel>
                                                <TextBlock Text="😎" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Casual" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Relajado y amigable" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="CardSarcastico" Tag="sarcastico"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="#1e1e1e" BorderThickness="1.5"
                                                Margin="0,5,5,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="Personality_Click">
                                            <StackPanel>
                                                <TextBlock Text="😏" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Sarcástico" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Ingenioso y mordaz" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="CardTecnico" Tag="tecnico"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="#1e1e1e" BorderThickness="1.5"
                                                Margin="5,5,0,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="Personality_Click">
                                            <StackPanel>
                                                <TextBlock Text="🔬" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Técnico" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Detallado y analítico" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Response Length -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="LONGITUD DE RESPUESTA" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ResponseLengthBox" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Conciso — respuestas breves" Tag="conciso"/>
                                        <ComboBoxItem Content="Normal — equilibrado" Tag="normal" IsSelected="True"/>
                                        <ComboBoxItem Content="Detallado — respuestas largas" Tag="detallado"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ────── PAGE 3: Rendimiento ────── -->
                <Grid x:Name="Page3" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,14,50,10">
                            <TextBlock Text="⚙  RENDIMIENTO" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,6"/>
                            <TextBlock Text="Ajusta según la potencia de tu equipo"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,22"/>

                            <!-- Hardware info -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="TU HARDWARE" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Border Background="#0a0a0a" CornerRadius="6" Padding="14,10"
                                            BorderBrush="#161616" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock x:Name="HwCpuText" Text="CPU: detectando..."
                                                       FontSize="10" Foreground="#808080" FontFamily="Consolas"/>
                                            <TextBlock x:Name="HwRamText" Text="RAM: detectando..."
                                                       FontSize="10" Foreground="#808080" FontFamily="Consolas" Margin="0,3,0,0"/>
                                            <TextBlock x:Name="HwRecommendText" Text=""
                                                       FontSize="10" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                                                       FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Mode cards -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="MODO DE RENDIMIENTO" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <UniformGrid Columns="2">
                                        <Border x:Name="CardLigero" Tag="ligero"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                                                Margin="0,0,5,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="PerfMode_Click">
                                            <StackPanel>
                                                <TextBlock Text="⚡" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Ligero" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Rápido, poca RAM" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                                <TextBlock Text="qwen2.5:7b · 4K ctx" FontSize="8"
                                                           Foreground="#666666" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="CardAvanzado" Tag="avanzado"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="#1e1e1e" BorderThickness="1.5"
                                                Margin="5,0,0,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="PerfMode_Click">
                                            <StackPanel>
                                                <TextBlock Text="🧠" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Avanzado" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Más contexto y detalle" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                                <TextBlock Text="qwen2.5:14b · 8K ctx" FontSize="8"
                                                           Foreground="#666666" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ────── PAGE 5: Sistema ────── -->
                <Grid x:Name="Page5" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,14,50,10">
                            <TextBlock Text="🖥  SISTEMA" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,6"/>
                            <TextBlock Text="Comportamiento y atajos del sistema"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,22"/>

                            <!-- Hotkeys -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="TECLAS RÁPIDAS" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Text="Mostrar / ocultar" FontSize="11"
                                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                            <TextBox x:Name="HotkeyShowBox" Style="{StaticResource AresTextBox}"
                                                     Text="Ctrl+Space"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="Cambiar modo" FontSize="11"
                                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                            <TextBox x:Name="HotkeyModeBox" Style="{StaticResource AresTextBox}"
                                                     Text="Ctrl+Shift+Space"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Toggles -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="COMPORTAMIENTO" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkLaunchWindows" Style="{StaticResource AresCheckBox}"
                                              Content="Iniciar con Windows"/>
                                    <CheckBox x:Name="ChkSaveChat" Style="{StaticResource AresCheckBox}"
                                              Content="Guardar historial del chat" IsChecked="True" Margin="0,8,0,0"/>
                                    <CheckBox x:Name="ChkCloseToTray" Style="{StaticResource AresCheckBox}"
                                              Content="Minimizar a la bandeja al cerrar" IsChecked="True" Margin="0,8,0,0"/>
                                    <CheckBox x:Name="ChkConfirmation" Style="{StaticResource AresCheckBox}"
                                              Content="Pedir confirmación en acciones peligrosas" IsChecked="True" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Keep alive -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16">
                                <StackPanel>
                                    <TextBlock Text="Descargar modelo de RAM tras inactividad" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="KeepAliveBox" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Nunca" Tag="0"/>
                                        <ComboBoxItem Content="1 minuto" Tag="1"/>
                                        <ComboBoxItem Content="5 minutos" Tag="5" IsSelected="True"/>
                                        <ComboBoxItem Content="10 minutos" Tag="10"/>
                                        <ComboBoxItem Content="30 minutos" Tag="30"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ────── PAGE 4: Voz ────── -->
                <Grid x:Name="Page4" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel HorizontalAlignment="Center" Margin="50,14,50,10">
                            <TextBlock Text="🔊  VOZ DEL ASISTENTE" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,6"/>
                            <TextBlock Text="Configura cómo habla tu asistente"
                                       FontSize="11" Foreground="#707070" HorizontalAlignment="Center"
                                       FontFamily="Consolas" Margin="0,0,0,22"/>

                            <!-- Enable voice -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVAR VOZ" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkVoice" Style="{StaticResource AresCheckBox}"
                                              Content="Leer respuestas en voz alta" IsChecked="False"/>
                                    <TextBlock Text="ARES leerá sus respuestas usando síntesis de voz neuronal"
                                               FontSize="10" Foreground="#606060" FontFamily="Consolas" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Gender cards -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="GÉNERO DE VOZ" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <UniformGrid Columns="2">
                                        <Border x:Name="CardMasculino" Tag="masculino"
                                                Background="#161616" CornerRadius="8"
                                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                                                Margin="0,0,5,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="VoiceGender_Click">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🗣" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Masculino" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Alvaro / Piper neural" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                                <TextBlock Text="Voz offline disponible" FontSize="8"
                                                           Foreground="#666666" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="CardFemenino" Tag="femenino"
                                                Background="#111111" CornerRadius="8"
                                                BorderBrush="#1e1e1e" BorderThickness="1.5"
                                                Margin="5,0,0,0" Padding="14,12" Cursor="Hand"
                                                MouseLeftButtonDown="VoiceGender_Click">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🗣" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                <TextBlock Text="Femenino" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Dalia / Piper neural" FontSize="9"
                                                           Foreground="#999999" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,4,0,0"/>
                                                <TextBlock Text="Voz offline disponible" FontSize="8"
                                                           Foreground="#666666" HorizontalAlignment="Center"
                                                           FontFamily="Consolas" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Volume -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="VOLUMEN" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="SetupVolumeSlider" Grid.Column="0"
                                                Minimum="0" Maximum="1" SmallChange="0.05" Value="0.5"
                                                VerticalAlignment="Center"
                                                ValueChanged="SetupVolume_ValueChanged"/>
                                        <TextBlock x:Name="SetupVolumeLabel" Grid.Column="1"
                                                   Text="50%" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="40"
                                                   TextAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Piper offline download -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16" Margin="0,0,0,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="VOZ OFFLINE (PIPER)" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Descarga las voces neuronales Piper para usar sin conexión (~140 MB total)"
                                               FontSize="10" Foreground="#606060" FontFamily="Consolas" Margin="0,0,0,12"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SetupDownloadPiper" Content="⬇  Descargar voces offline"
                                                Style="{StaticResource GhostButton}"
                                                Height="34" Padding="20,0"
                                                HorizontalAlignment="Left" Cursor="Hand"
                                                FontFamily="Consolas" FontSize="12"
                                                Click="SetupDownloadPiper_Click"/>
                                        <TextBlock x:Name="PiperDownloadStatus" Text=""
                                                   FontSize="10" Foreground="#808080" FontFamily="Consolas"
                                                   VerticalAlignment="Center" Margin="14,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Test voice -->
                            <Border Background="#0b0b0b" CornerRadius="10"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="22,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                                   Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="PRUEBA DE VOZ" FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Escucha cómo suena tu asistente con la configuración actual"
                                               FontSize="10" Foreground="#606060" FontFamily="Consolas" Margin="0,0,0,12"/>
                                    <Button x:Name="SetupTestVoice" Content="▶  Probar voz"
                                            Style="{StaticResource GhostButton}"
                                            Height="34" Padding="20,0"
                                            HorizontalAlignment="Left" Cursor="Hand"
                                            FontFamily="Consolas" FontSize="12"
                                            Click="SetupTestVoice_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- ══════════  NAVIGATION  ══════════ -->
            <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="24,10,24,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0c0c0c" Offset="0"/>
                        <GradientStop Color="#080808" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border VerticalAlignment="Top" Height="1" Background="#1a1a1a" Margin="-24,0"/>

                    <!-- Step label -->
                    <TextBlock x:Name="StepLabel" Text="Paso 1 de 5" FontSize="10"
                               Foreground="#505050" FontFamily="Consolas"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Bottom" Margin="0,20,0,0">
                        <Button x:Name="BtnBack" Content="← ATRÁS"
                                Style="{StaticResource GhostButton}"
                                Width="130" Height="38"
                                FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                                Click="Back_Click" Cursor="Hand"
                                Visibility="Collapsed" Margin="0,0,12,0"/>
                        <Button x:Name="BtnNext" Content="SIGUIENTE →"
                                Style="{StaticResource AresButton}"
                                Width="180" Height="42"
                                FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                Click="Next_Click" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="30" To="0" Duration="0:0:0.7">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="DiamondRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:8"/>
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.9" To="1.08" Duration="0:0:2"
                                     AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.9" To="1.08" Duration="0:0:2"
                                     AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
