<Window x:Class="AresAssistant.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES" Height="420" Width="500"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="#0d0d0d" CornerRadius="12"
            BorderBrush="#ff2222" BorderThickness="1">
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Animated ARES Logo -->
                <Canvas Width="140" Height="140" HorizontalAlignment="Center" Margin="0,0,0,20">

                    <!-- Outer glow ring (pulse) -->
                    <Ellipse x:Name="Ring1" Width="130" Height="130"
                             Canvas.Left="5" Canvas.Top="5"
                             Stroke="#22ff2222" StrokeThickness="8"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="Ring1Scale" ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Mid ring -->
                    <Ellipse x:Name="Ring2" Width="104" Height="104"
                             Canvas.Left="18" Canvas.Top="18"
                             Stroke="#55ff2222" StrokeThickness="1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="Ring2Scale" ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Inner ring -->
                    <Ellipse Width="76" Height="76"
                             Canvas.Left="32" Canvas.Top="32"
                             Stroke="#88ff2222" StrokeThickness="1"/>

                    <!-- Crosshair lines (fixed, behind diamond) -->
                    <Line X1="0" Y1="70" X2="42" Y2="70"
                          Stroke="#ff2222" StrokeThickness="1" Opacity="0.6"/>
                    <Line X1="98" Y1="70" X2="140" Y2="70"
                          Stroke="#ff2222" StrokeThickness="1" Opacity="0.6"/>
                    <Line X1="70" Y1="0" X2="70" Y2="42"
                          Stroke="#ff2222" StrokeThickness="1" Opacity="0.6"/>
                    <Line X1="70" Y1="98" X2="70" Y2="140"
                          Stroke="#ff2222" StrokeThickness="1" Opacity="0.6"/>

                    <!-- Corner tick marks -->
                    <Line X1="0" Y1="0" X2="12" Y2="0" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="0" Y1="0" X2="0" Y2="12" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="128" Y1="0" X2="140" Y2="0" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="140" Y1="0" X2="140" Y2="12" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="0" Y1="128" X2="0" Y2="140" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="0" Y1="140" X2="12" Y2="140" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="140" Y1="128" X2="140" Y2="140" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>
                    <Line X1="128" Y1="140" X2="140" Y2="140" Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.5"/>

                    <!-- Diamond outer (border only) — rotates -->
                    <Path Canvas.Left="42" Canvas.Top="28"
                          Fill="Transparent"
                          Stroke="#ff2222" StrokeThickness="1.5" Opacity="0.6"
                          Data="M 28,0 L 56,42 L 28,84 L 0,42 Z">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="DiamondOuterRotate" Angle="0" CenterX="28" CenterY="42"/>
                        </Path.RenderTransform>
                    </Path>

                    <!-- Diamond inner (filled) — rotates opposite -->
                    <Path Canvas.Left="54" Canvas.Top="42"
                          Stroke="#ff2222" StrokeThickness="1"
                          Opacity="1"
                          Data="M 16,0 L 32,24 L 16,48 L 0,24 Z">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#ff2222" Offset="0"/>
                                <GradientStop Color="#cc0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                        <Path.RenderTransform>
                            <RotateTransform x:Name="DiamondRotate" Angle="0" CenterX="16" CenterY="24"/>
                        </Path.RenderTransform>
                        <Path.Effect>
                            <DropShadowEffect Color="#ff2222" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                        </Path.Effect>
                    </Path>

                    <!-- Center dot -->
                    <Ellipse Width="6" Height="6"
                             Canvas.Left="67" Canvas.Top="67"
                             Fill="#ff2222">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#ff2222" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>

                <!-- ARES Title -->
                <TextBlock Text="ARES" FontSize="32" FontWeight="Bold"
                           Foreground="#ff2222" HorizontalAlignment="Center"
                           FontFamily="Consolas" Margin="0,0,0,8"/>

                <TextBlock Text="Autonomous Response Engine System"
                           FontSize="11" Foreground="#666666"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText"
                           Text="Inicializando..."
                           FontSize="13" Foreground="#aaaaaa"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"
                           Margin="0,8,0,0"/>

                <!-- Progress bar -->
                <ProgressBar x:Name="ProgressBar" Width="300" Height="3"
                             Background="#1a1a1a" Foreground="#ff2222"
                             BorderThickness="0" Minimum="0" Maximum="100"
                             Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <!-- Inner diamond slow rotation -->
                    <DoubleAnimation Storyboard.TargetName="DiamondRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:6"/>
                    <!-- Outer diamond border rotates opposite, faster -->
                    <DoubleAnimation Storyboard.TargetName="DiamondOuterRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="360" To="0" Duration="0:0:10"/>
                    <!-- Ring1 outer glow pulse -->
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.85" To="1.1" Duration="0:0:2"
                                     AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="Ring1Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.85" To="1.1" Duration="0:0:2"
                                     AutoReverse="True"/>
                    <!-- Ring2 mid pulse (offset phase) -->
                    <DoubleAnimation Storyboard.TargetName="Ring2Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1.0" To="1.08" Duration="0:0:1.5"
                                     AutoReverse="True" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="Ring2Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1.0" To="1.08" Duration="0:0:1.5"
                                     AutoReverse="True" BeginTime="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
