<Window x:Class="AresAssistant.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Ajustes"
        Width="640" Height="940"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder"
            CornerRadius="14"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
            Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0f0f0f" Offset="0"/>
                <GradientStop Color="#070707" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="20"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <!-- ════════ Accent glow line ════════ -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="14,14,0,0"
                    Margin="80,0" Opacity="0.8" IsHitTestVisible="False" Grid.RowSpan="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="{DynamicResource AccentMediaColor}" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ════════ Header ════════ -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#121212" Offset="0"/>
                        <GradientStop Color="#0a0a0a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Mini diamond icon -->
                        <Path Data="M 6,0 L 12,9 L 6,18 L 0,9 Z"
                              Fill="{DynamicResource AccentBrush}" Width="10" Height="16" Margin="0,0,10,0"
                              VerticalAlignment="Center">
                            <Path.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentMediaColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Text="AJUSTES" FontFamily="Consolas" FontSize="14"
                                   FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{DynamicResource GhostButton}"
                            Click="Close_Click" Width="28" Height="28" Padding="0"/>
                </Grid>
            </Border>

            <!-- ════════ Scrollable Content ════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="18,14,18,10">

                    <!-- ═══════════════════ APARIENCIA ═══════════════════ -->
                    <Border Background="#0b0b0b" CornerRadius="10"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="APARIENCIA" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Color de acento" FontSize="11"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,7"/>

                            <!-- Live preview bar -->
                            <Border Height="34" CornerRadius="6" Margin="0,0,0,10"
                                    Background="{Binding AccentColor, Converter={StaticResource HexToColorBrushConverter}}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="14" Opacity="0.45" Color="#000000"/>
                                </Border.Effect>
                                <TextBlock Text="{Binding AccentColor}" FontFamily="Consolas" FontSize="11"
                                           Foreground="#FFFFFFBB"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>

                            <!-- Swatches -->
                            <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Button Tag="#ff2222" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Rojo">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#ff2222"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#ff6600" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Naranja">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#ff6600"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#ffcc00" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Dorado">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#ffcc00"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#22dd55" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Verde">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#22dd55"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#00aaff" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Azul">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#00aaff"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#8855ff" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Violeta">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#8855ff"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#ff44cc" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Rosa">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#ff44cc"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#00ddc8" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Turquesa">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#00ddc8"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                                <Button Tag="#aaaaaa" Click="PresetColor_Click" Width="34" Height="34" Margin="2" Cursor="Hand" ToolTip="Plata">
                                    <Button.Template><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="R" Width="28" Height="28" Stroke="Transparent" StrokeThickness="2.5"/><Ellipse Width="20" Height="20" Fill="#aaaaaa"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="R" Property="Stroke" Value="#88ffffff"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>
                            </WrapPanel>

                            <!-- Swatch + Hex -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Width="34" Height="34"
                                        Click="PickColor_Click" ToolTip="Elegir color"
                                        Cursor="Hand" Margin="0,0,4,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Swatch" CornerRadius="6"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    Background="{Binding AccentColor, Converter={StaticResource HexToColorBrushConverter}}"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Swatch" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox Grid.Column="1" Style="{StaticResource AresTextBox}"
                                         Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- Font size + Opacity -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Tamaño de fuente" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding FontSize}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Pequeño" Tag="small"/>
                                        <ComboBoxItem Content="Normal" Tag="medium"/>
                                        <ComboBoxItem Content="Grande" Tag="large"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <Grid Margin="0,0,0,5">
                                        <TextBlock Text="Opacidad" FontSize="11"
                                                   Foreground="{DynamicResource SubtextBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Text="{Binding OverlayOpacity, StringFormat='{}{0:P0}'}"/>
                                    </Grid>
                                    <Slider Minimum="0.3" Maximum="1.0" Value="{Binding OverlayOpacity}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Position -->
                            <TextBlock Text="Posición del overlay" FontSize="11"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                            <ComboBox SelectedValue="{Binding OverlayPosition}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Abajo — derecha" Tag="bottom-right"/>
                                <ComboBoxItem Content="Abajo — izquierda" Tag="bottom-left"/>
                                <ComboBoxItem Content="Arriba — derecha" Tag="top-right"/>
                                <ComboBoxItem Content="Arriba — izquierda" Tag="top-left"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════ INTELIGENCIA ARTIFICIAL ═══════════════════ -->
                    <Border Background="#0b0b0b" CornerRadius="10"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="INTELIGENCIA ARTIFICIAL" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,10">
                                    <TextBlock Text="Modelo de Ollama" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox Text="{Binding OllamaModel}" IsEditable="True"
                                              ItemsSource="{Binding AvailableModels}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="6,0,0,10">
                                    <TextBlock Text="Nombre del asistente" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <TextBox Style="{StaticResource AresTextBox}"
                                             Text="{Binding AssistantName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,6,10">
                                    <TextBlock Text="Personalidad" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding Personality}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Formal" Tag="formal"/>
                                        <ComboBoxItem Content="Casual" Tag="casual"/>
                                        <ComboBoxItem Content="Sarcástico" Tag="sarcastico"/>
                                        <ComboBoxItem Content="Técnico" Tag="tecnico"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,10">
                                    <TextBlock Text="Longitud de respuesta" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding ResponseLength}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Conciso" Tag="conciso"/>
                                        <ComboBoxItem Content="Normal" Tag="normal"/>
                                        <ComboBoxItem Content="Detallado" Tag="detallado"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Ollama status + check button — FIX: proper layout -->
                                <Border Grid.Row="2" Grid.ColumnSpan="2"
                                        Background="#0e0e0e" CornerRadius="6"
                                        BorderBrush="#1a1a1a" BorderThickness="1"
                                        Padding="12,8" Margin="0,2,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding OllamaStatus}" FontSize="11"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                                   FontFamily="Consolas"/>
                                        <Button Grid.Column="1" Content="Verificar"
                                                Style="{StaticResource GhostButton}"
                                                Height="30" Padding="14,0"
                                                Margin="10,0,0,0" Click="CheckOllama_Click"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════ RENDIMIENTO ═══════════════════ -->
                    <Border Background="#0b0b0b" CornerRadius="10"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="RENDIMIENTO" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Hardware info -->
                            <Border Background="#0a0a0a" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                                    BorderBrush="#161616" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding HwCpuInfo}" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding HwRamInfo}" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}" FontFamily="Consolas" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding HwRecommendation}" FontSize="10"
                                               Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                                               FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Mode selector -->
                            <TextBlock Text="Modo" FontSize="11"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                            <ComboBox SelectedValue="{Binding PerformanceMode}" SelectedValuePath="Tag">
                                <ComboBoxItem Tag="ligero">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" Margin="0,0,6,0"/>
                                        <TextBlock Text="Ligero — rápido, poca RAM (2K ctx)"/>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="avanzado">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧠" Margin="0,0,6,0"/>
                                        <TextBlock Text="Avanzado — más contexto (8K ctx)"/>
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════ TECLAS RÁPIDAS ═══════════════════ -->
                    <Border Background="#0b0b0b" CornerRadius="10"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="TECLAS RÁPIDAS" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Mostrar / ocultar" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <TextBox Style="{StaticResource AresTextBox}"
                                             Text="{Binding ShowHideHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Cambiar modo" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,5"/>
                                    <TextBox Style="{StaticResource AresTextBox}"
                                             Text="{Binding ToggleModeHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════ SISTEMA ═══════════════════ -->
                    <Border Background="#0b0b0b" CornerRadius="10"
                            BorderBrush="#1a1a1a" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="SISTEMA" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <CheckBox Style="{StaticResource AresCheckBox}"
                                      Content="Iniciar con Windows"
                                      IsChecked="{Binding LaunchWithWindows}"/>
                            <CheckBox Style="{StaticResource AresCheckBox}"
                                      Content="Guardar historial del chat"
                                      IsChecked="{Binding SaveChatHistory}" Margin="0,6,0,0"/>
                            <CheckBox Style="{StaticResource AresCheckBox}"
                                      Content="Minimizar a la bandeja al cerrar"
                                      IsChecked="{Binding CloseToTray}" Margin="0,6,0,0"/>
                            <CheckBox Style="{StaticResource AresCheckBox}"
                                      Content="Pedir confirmación en acciones peligrosas"
                                      IsChecked="{Binding ConfirmationAlertsEnabled}" Margin="0,6,0,0"/>
                            <CheckBox Style="{StaticResource AresCheckBox}"
                                      Content="Voz del asistente (leer respuestas en voz alta)"
                                      IsChecked="{Binding VoiceEnabled}" Margin="0,6,0,0"/>

                            <!-- TTS engine status + volume -->
                            <Border Margin="0,8,0,0" Background="#0e0e0e" CornerRadius="6"
                                    BorderBrush="#1a1a1a" BorderThickness="1" Padding="12,10">
                                <StackPanel>
                                    <!-- Voice gender -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Género de voz" FontSize="11"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Column="1"
                                                  SelectedValue="{Binding TtsVoiceGender}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="Masculino — Alvaro / Piper" Tag="masculino"/>
                                            <ComboBoxItem Content="Femenino — Dalia / Piper" Tag="femenino"/>
                                        </ComboBox>
                                    </Grid>
                                    <!-- Volume row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Volumen" FontSize="11"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0" Maximum="1" SmallChange="0.05"
                                                Value="{Binding TtsVolume, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TtsVolume, StringFormat='{}{0:P0}'}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="36"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                    <!-- Engine status + buttons row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TtsEngineStatus}" FontSize="10"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" FontFamily="Consolas"/>
                                        <Button Grid.Column="1" Content="⬇ Piper offline"
                                                Style="{StaticResource GhostButton}"
                                                Visibility="{Binding PiperButtonVisible}"
                                                IsEnabled="{Binding CanDownloadPiper}"
                                                Height="26" Padding="10,0" Margin="8,0,0,0"
                                                Click="DownloadPiper_Click"/>
                                        <Button Grid.Column="2" Content="▶ Probar"
                                                Style="{StaticResource GhostButton}"
                                                Height="26" Padding="10,0" Margin="6,0,0,0"
                                                Click="TestVoice_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Descargar modelo tras" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox SelectedValue="{Binding ModelKeepAliveMinutes}"
                                              SelectedValuePath="Tag" Width="110">
                                        <ComboBoxItem Content="Nunca" Tag="0"/>
                                        <ComboBoxItem Content="1 min" Tag="1"/>
                                        <ComboBoxItem Content="5 min" Tag="5"/>
                                        <ComboBoxItem Content="10 min" Tag="10"/>
                                        <ComboBoxItem Content="30 min" Tag="30"/>
                                    </ComboBox>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Reescanear"
                                        Style="{StaticResource GhostButton}"
                                        Height="30" Padding="14,0"
                                        Click="Rescan_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════ ZONA DE PELIGRO ═══════════════════ -->
                    <Border Background="#110a0a" CornerRadius="10"
                            BorderBrush="#3a1515" BorderThickness="1" Padding="18,14" Margin="0,0,0,4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Rectangle Width="2.5" Height="13" RadiusX="1" RadiusY="1"
                                           Fill="#cc3333" VerticalAlignment="Center"/>
                                <TextBlock Text="ZONA DE PELIGRO" FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="#cc3333"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Elimina permanentemente todos los datos almacenados: historial de chat, configuración personalizada, herramientas escaneadas y registros."
                                       FontSize="11" Foreground="#aa8888" TextWrapping="Wrap"
                                       Margin="0,0,0,12" FontFamily="Consolas"/>
                            <Button Content="⚠  Borrar todos los datos"
                                    Style="{StaticResource GhostButton}"
                                    Foreground="#cc3333"
                                    Height="34" Padding="16,0"
                                    HorizontalAlignment="Left" Cursor="Hand"
                                    Click="PurgeData_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ════════ Footer ════════ -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" Padding="20,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0d0d0d" Offset="0"/>
                        <GradientStop Color="#080808" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Subtle separator line -->
                <Grid>
                    <Border VerticalAlignment="Top" Height="1" Background="#1a1a1a" Margin="-20,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Cancelar" Style="{StaticResource GhostButton}"
                                Width="110" Height="32" Click="Cancel_Click" Margin="0,0,8,0"/>
                        <Button Content="Guardar" Style="{StaticResource AresButton}"
                                Width="110" Height="32" Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <!-- Entrance: fade + slide up -->
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="20" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
