<Window x:Class="AresAssistant.Views.ModelDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARES — Descargando modelo"
        Width="480" Height="290"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder" CornerRadius="20"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Opacity="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                <GradientStop Color="#0e0e18" Offset="0"/>
                <GradientStop Color="#06060c" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="14"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="45" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <!-- Top accent glow line -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="20,20,0,0"
                    Margin="60,0" Opacity="0.8" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#ff2222" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="26,20,26,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <Path Data="M 8,0 L 16,11 L 8,22 L 0,11 Z"
                          Fill="{DynamicResource AccentBrush}" Width="13" Height="19"
                          Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path.Effect>
                            <DropShadowEffect Color="#ff2222" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Path.Effect>
                    </Path>
                    <TextBlock Text="Descargando modelo" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Glass progress panel -->
                <Border Grid.Row="1"
                        Background="{DynamicResource GlassBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16,14">
                    <StackPanel>

                        <!-- Model name -->
                        <TextBlock x:Name="TxtModelName"
                                   FontSize="12" Foreground="{DynamicResource SubtextBrush}"
                                   FontFamily="Consolas" Margin="0,0,0,12"/>

                        <!-- Progress bar -->
                        <Grid Margin="0,0,0,8">
                            <Border Background="#0a0a14" CornerRadius="4" Height="8"
                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"/>
                            <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                                    CornerRadius="4" Height="8" Width="0"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.7" Color="#ff2222"/>
                                </Border.Effect>
                            </Border>
                        </Grid>

                        <!-- Percentage + size -->
                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="TxtPercentage" Text="0 %"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontFamily="Consolas" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtSize" Text=""
                                       FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- Status with prefix -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="›" Foreground="{DynamicResource AccentBrush}"
                                       FontFamily="Consolas" FontSize="11"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus" Text="Conectando..."
                                       FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Spacer -->
                <Border Grid.Row="2"/>

                <!-- Cancel -->
                <Button x:Name="BtnCancel" Grid.Row="3" Content="Cancelar"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Width="100"
                        Click="BtnCancel_Click"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
